#!/bin/sh
set -e

# Install Ollama binary into the chroot
OLLAMA_VER="0.24.0"
apt-get install -y --no-install-recommends zstd >/dev/null 2>&1 || true
curl -fL --retry 3 -o /tmp/ollama.tar.zst \
  "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VER}/ollama-linux-amd64.tar.zst"
tar --zstd -xf /tmp/ollama.tar.zst -C /usr --strip-components=0
rm -f /tmp/ollama.tar.zst
chmod 755 /usr/bin/ollama

getent group ollama  >/dev/null || groupadd --system ollama
getent passwd ollama >/dev/null || \
  useradd --system --gid ollama --home /var/lib/ollama --shell /usr/sbin/nologin ollama
mkdir -p /var/lib/ollama/models
chown -R ollama:ollama /var/lib/ollama

# Pre-baked model blob staged via includes.chroot/var/lib/ollama/models/blobs/

systemctl enable vitos-firstboot.service \
                 vitos-busd.service \
                 vitos-bpf-exec.service \
                 vitos-bpf-net.service \
                 vitos-shell-tap.service \
                 vitos-udev-tap.service \
                 vitos-fanotify-tap.service \
                 ollama.service \
                 vitos-ai.service \
                 lightdm.service || true

# volatility3 — not in Kali main; install via pip so the forensics launcher
# works fully offline on lab machines (baked into the squashfs at build time).
# Best-effort: never fail the build (mirrors the firejail-vendoring philosophy).
# The pip console script is `vol`, but vitos-run dispatches on the name
# 'volatility3' (the symlink basename), so we also drop a /usr/bin/volatility3
# shim that execs `vol`.
if ! command -v vol >/dev/null 2>&1; then
    pip3 install --break-system-packages volatility3 >/dev/null 2>&1 \
      || pipx install volatility3 >/dev/null 2>&1 \
      || echo "WARNING: volatility3 install failed (forensics launcher will report 'not installed')"
fi
if command -v vol >/dev/null 2>&1 && [ ! -e /usr/bin/volatility3 ]; then
    cat > /usr/bin/volatility3 <<'VOL'
#!/bin/sh
exec vol "$@"
VOL
    chmod +x /usr/bin/volatility3
fi

passwd -l root || true
