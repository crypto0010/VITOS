# ── show.qml — animated dark slideshow ──────────────────────
cat > "$BRAND/show.qml" << 'QML'
import QtQuick 2.0

Rectangle {
    id: presentation
    anchors.fill: parent
    color: "#0d1117"

    property int currentIndex: 0
    property int slideCount: 5

    /* ── Slide 0: Welcome ── */
    Item {
        anchors.fill: parent
        anchors.bottomMargin: 50
        opacity: presentation.currentIndex === 0 ? 1.0 : 0.0
        visible: opacity > 0
        Behavior on opacity { NumberAnimation { duration: 500 } }

        Column {
            anchors.centerIn: parent
            spacing: 16
            width: parent.width * 0.75

            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "VITOS"
                font.pixelSize: 52
                font.weight: Font.Bold
                font.letterSpacing: 10
                color: "#ffffff"
            }
            Rectangle {
                anchors.horizontalCenter: parent.horizontalCenter
                width: 80; height: 3; radius: 2; color: "#4CB5F5"
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Developed by Dr. Hemraj"
                font.pixelSize: 18; font.weight: Font.DemiBold
                color: "#4CB5F5"
                horizontalAlignment: Text.AlignHCenter
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "VIT Bhopal University"
                font.pixelSize: 14; color: "#8b949e"
                horizontalAlignment: Text.AlignHCenter
            }
            Item { width: 1; height: 12 }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                width: parent.width
                text: "A purpose-built cybersecurity lab OS for education,\nresearch, and hands-on training."
                font.pixelSize: 14; color: "#8b949e"
                horizontalAlignment: Text.AlignHCenter
                lineHeight: 1.6; wrapMode: Text.WordWrap
            }
            Item { width: 1; height: 24 }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Installing — this may take a few minutes..."
                font.pixelSize: 13; color: "#6b7394"; font.italic: true
            }
        }
    }

    /* ── Slide 1: Security Tools ── */
    Item {
        anchors.fill: parent
        anchors.bottomMargin: 50
        opacity: presentation.currentIndex === 1 ? 1.0 : 0.0
        visible: opacity > 0
        Behavior on opacity { NumberAnimation { duration: 500 } }

        Column {
            anchors.centerIn: parent
            spacing: 16
            width: parent.width * 0.75

            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Professional Security Suite"
                font.pixelSize: 28; font.weight: Font.Bold; color: "#ffffff"
            }
            Rectangle {
                anchors.horizontalCenter: parent.horizontalCenter
                width: 60; height: 3; radius: 2; color: "#4CB5F5"
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Pre-configured & Ready to Use"
                font.pixelSize: 15; color: "#4CB5F5"
            }
            Item { width: 1; height: 8 }
            Grid {
                anchors.horizontalCenter: parent.horizontalCenter
                columns: 2; columnSpacing: 48; rowSpacing: 12
                Text { text: "•  Metasploit Framework"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Burp Suite"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Ghidra"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Wireshark"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Nmap"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Aircrack-ng"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  John the Ripper"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  SQLMap"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Hashcat"; font.pixelSize: 13; color: "#e6edf3" }
                Text { text: "•  Radare2"; font.pixelSize: 13; color: "#e6edf3" }
            }
            Item { width: 1; height: 8 }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "...and 30+ more security tools"
                font.pixelSize: 13; color: "#6b7394"; font.italic: true
            }
        }
    }

    /* ── Slide 2: AI ── */
    Item {
        anchors.fill: parent
        anchors.bottomMargin: 50
        opacity: presentation.currentIndex === 2 ? 1.0 : 0.0
        visible: opacity > 0
        Behavior on opacity { NumberAnimation { duration: 500 } }

        Column {
            anchors.centerIn: parent
            spacing: 16
            width: parent.width * 0.75

            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "AI-Powered Analysis"
                font.pixelSize: 28; font.weight: Font.Bold; color: "#ffffff"
            }
            Rectangle {
                anchors.horizontalCenter: parent.horizontalCenter
                width: 60; height: 3; radius: 2; color: "#4CB5F5"
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Local AI with Ollama + Gemma 3"
                font.pixelSize: 15; color: "#4CB5F5"
            }
            Item { width: 1; height: 8 }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                width: parent.width
                text: "VITOS includes a pre-loaded Gemma 3 language model\nrunning locally via Ollama for intelligent security analysis.\n\nAnalyze logs, review code for vulnerabilities, get explanations\nof attack techniques — all completely offline and private.\n\nNo cloud dependency. No data leaves your machine."
                font.pixelSize: 14; color: "#8b949e"
                horizontalAlignment: Text.AlignHCenter
                lineHeight: 1.6; wrapMode: Text.WordWrap
            }
        }
    }

    /* ── Slide 3: Hardening ── */
    Item {
        anchors.fill: parent
        anchors.bottomMargin: 50
        opacity: presentation.currentIndex === 3 ? 1.0 : 0.0
        visible: opacity > 0
        Behavior on opacity { NumberAnimation { duration: 500 } }

        Column {
            anchors.centerIn: parent
            spacing: 16
            width: parent.width * 0.75

            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Hardened by Default"
                font.pixelSize: 28; font.weight: Font.Bold; color: "#ffffff"
            }
            Rectangle {
                anchors.horizontalCenter: parent.horizontalCenter
                width: 60; height: 3; radius: 2; color: "#4CB5F5"
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Security-First Architecture"
                font.pixelSize: 15; color: "#4CB5F5"
            }
            Item { width: 1; height: 8 }
            Column {
                anchors.horizontalCenter: parent.horizontalCenter
                spacing: 14
                Text { text: "▸  Firejail application sandboxing"; font.pixelSize: 14; color: "#e6edf3" }
                Text { text: "▸  Comprehensive audit logging"; font.pixelSize: 14; color: "#e6edf3" }
                Text { text: "▸  PAM consent workflows"; font.pixelSize: 14; color: "#e6edf3" }
                Text { text: "▸  Role-based access (admin / student)"; font.pixelSize: 14; color: "#e6edf3" }
                Text { text: "▸  Encrypted DNS via dnscrypt-proxy"; font.pixelSize: 14; color: "#e6edf3" }
                Text { text: "▸  Account lockout after failed logins"; font.pixelSize: 14; color: "#e6edf3" }
            }
        }
    }

    /* ── Slide 4: University ── */
    Item {
        anchors.fill: parent
        anchors.bottomMargin: 50
        opacity: presentation.currentIndex === 4 ? 1.0 : 0.0
        visible: opacity > 0
        Behavior on opacity { NumberAnimation { duration: 500 } }

        Column {
            anchors.centerIn: parent
            spacing: 16
            width: parent.width * 0.75

            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Built for Learning"
                font.pixelSize: 28; font.weight: Font.Bold; color: "#ffffff"
            }
            Rectangle {
                anchors.horizontalCenter: parent.horizontalCenter
                width: 60; height: 3; radius: 2; color: "#4CB5F5"
            }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                text: "Developed by Dr. Hemraj"
                font.pixelSize: 15; color: "#4CB5F5"
            }
            Item { width: 1; height: 8 }
            Text {
                anchors.horizontalCenter: parent.horizontalCenter
                width: parent.width
                text: "VIT Bhopal University\nDepartment of Computer Science & Engineering\n\nDesigned for students and faculty in cybersecurity programs.\nDual admin/student roles with guided workflows\nfor structured lab environments.\n\nEvery tool configured, every service hardened —\nso you can focus on learning."
                font.pixelSize: 14; color: "#8b949e"
                horizontalAlignment: Text.AlignHCenter
                lineHeight: 1.6; wrapMode: Text.WordWrap
            }
        }
    }

    /* ── Slide indicators ── */
    Row {
        anchors.bottom: parent.bottom
        anchors.bottomMargin: 16
        anchors.horizontalCenter: parent.horizontalCenter
        spacing: 10

        Repeater {
            model: presentation.slideCount
            Rectangle {
                width: index === presentation.currentIndex ? 28 : 8
                height: 8; radius: 4
                color: index === presentation.currentIndex ? "#4CB5F5" : "#21262d"
                Behavior on width { NumberAnimation { duration: 300; easing.type: Easing.OutCubic } }
                Behavior on color { ColorAnimation { duration: 300 } }
            }
        }
    }

    /* ── Auto-advance ── */
    Timer {
        interval: 8000; running: true; repeat: true
        onTriggered: {
            presentation.currentIndex = (presentation.currentIndex + 1) % presentation.slideCount
        }
    }
}
QML

# ── Module configs ───────────────────────────────────────────

cat > "$MODULES/unpackfs.conf" << 'EOF'
---
unpack:
    - source: "/run/live/medium/live/filesystem.squashfs"
      sourcefs: "squashfs"
      destination: ""
EOF

# ── grub-install interception via dpkg-divert ───────────────
# Calamares's bootloader module calls grub-install INSIDE the target chroot
# (check_target_env_call) and ABORTS the whole install if it returns non-zero.
# On VMs/OVMF/Secure-Boot/full-NVRAM machines the stock call returns exit 1
# because it can't write the UEFI NVRAM variable -> "Bootloader installation
# error" (the failure in error2.jpeg). Because the bootloader module runs
# grub-install BEFORE grub-mkconfig, that abort also means /boot/grub/grub.cfg
# is never generated. We divert /usr/sbin/grub-install to a wrapper that always
# lands a bootable artifact and never aborts the install. The wrapper is a
# committed, separately-tested file
# (includes.chroot/usr/local/share/vitos/grub-install) so CI exercises the exact
# same code that ships — see .github/workflows/verify-bootloader.yml.
#
# CRITICAL ORDERING: the real grub-install (grub-common) and the x86_64-efi
# modules (grub-efi-amd64-bin) MUST already be in the chroot before we divert —
# otherwise dpkg-divert --rename has nothing to rename, .distrib is absent, and
# the wrapper has no real binary to call. These are in package-lists/, but we
# re-assert them here and FAIL THE BUILD if anything is missing. Previously this
# only WARNED, which let bootloader-broken ISOs ship silently.
echo "Ensuring grub EFI bootloader + modules are present BEFORE diverting..."
for pkg in grub-common grub2-common grub-efi-amd64 grub-efi-amd64-bin efibootmgr; do
    if ! dpkg -s "$pkg" >/dev/null 2>&1; then
        echo "  installing missing package: $pkg"
        apt-get install -y "$pkg" || true
    fi
done

if [ ! -x /usr/sbin/grub-install ]; then
    echo "FATAL: /usr/sbin/grub-install absent after installing grub-common — cannot build a bootable VITOS" >&2
    exit 1
fi
if ! { [ -d /usr/lib/grub/x86_64-efi ] && ls /usr/lib/grub/x86_64-efi/*.mod >/dev/null 2>&1; }; then
    echo "FATAL: /usr/lib/grub/x86_64-efi modules missing — grub-install would fail in the target" >&2
    exit 1
fi
echo "OK: real grub-install present and $(ls /usr/lib/grub/x86_64-efi/*.mod | wc -l) x86_64-efi modules present"

echo "Diverting grub-install to the VITOS NVRAM-safe wrapper..."
WRAPPER_SRC=/usr/local/share/vitos/grub-install
if [ ! -f "$WRAPPER_SRC" ]; then
    echo "FATAL: $WRAPPER_SRC not found — the grub-install wrapper is missing from includes.chroot" >&2
    exit 1
fi
dpkg-divert --local --rename --add /usr/sbin/grub-install 2>/dev/null || true
cp "$WRAPPER_SRC" /usr/sbin/grub-install
chmod +x /usr/sbin/grub-install
# Sanity: the divert MUST have produced the real binary at .distrib (else the
# wrapper has nothing to call) and our wrapper MUST be in place. Fail the build
# rather than ship a non-functional bootloader.
if [ ! -x /usr/sbin/grub-install.distrib ]; then
    echo "FATAL: grub-install.distrib missing after divert — wrapper would be non-functional" >&2
    exit 1
fi
if ! grep -q "VITOS grub-install wrapper" /usr/sbin/grub-install; then
    echo "FATAL: /usr/sbin/grub-install is not the VITOS wrapper after copy" >&2
    exit 1
fi
echo "grub-install wrapper installed (real binary at /usr/sbin/grub-install.distrib)"

# ── grub-mkconfig interception via dpkg-divert ──────────────
# The bootloader module's SECOND command is `grub-mkconfig -o /boot/grub/grub.cfg`,
# run AFTER grub-install. Calamares aborts the whole install if it returns
# non-zero — the failure captured in VITOS Error.mp4 ("...the installation command
# grub-mkconfig -o /boot/grub/grub.cfg returned error code 1"). grub-mkconfig
# commonly exits non-zero on real hardware/VMs (grub-probe cannot canonicalize a
# device, or os-prober errors while scanning other disks) even when a perfectly
# bootable config could be produced. The grub-install wrapper does NOT cover this:
# it is a separate command. We divert grub-mkconfig to a wrapper that keeps any
# valid grub.cfg the real command wrote, else hand-writes a bootable one, and
# ALWAYS exits 0 — mirroring the grub-install wrapper above. The wrapper is a
# committed, separately-tested file exercised by verify-bootloader.yml.
echo "Diverting grub-mkconfig to the VITOS never-abort wrapper..."
if [ ! -x /usr/sbin/grub-mkconfig ]; then
    echo "FATAL: /usr/sbin/grub-mkconfig absent after installing grub-common — cannot guarantee grub.cfg" >&2
    exit 1
fi
MKCFG_WRAPPER_SRC=/usr/local/share/vitos/grub-mkconfig
if [ ! -f "$MKCFG_WRAPPER_SRC" ]; then
    echo "FATAL: $MKCFG_WRAPPER_SRC not found — the grub-mkconfig wrapper is missing from includes.chroot" >&2
    exit 1
fi
dpkg-divert --local --rename --add /usr/sbin/grub-mkconfig 2>/dev/null || true
cp "$MKCFG_WRAPPER_SRC" /usr/sbin/grub-mkconfig
chmod +x /usr/sbin/grub-mkconfig
if [ ! -x /usr/sbin/grub-mkconfig.distrib ]; then
    echo "FATAL: grub-mkconfig.distrib missing after divert — wrapper would be non-functional" >&2
    exit 1
fi
if ! grep -q "VITOS grub-mkconfig wrapper" /usr/sbin/grub-mkconfig; then
    echo "FATAL: /usr/sbin/grub-mkconfig is not the VITOS wrapper after copy" >&2
    exit 1
fi
echo "grub-mkconfig wrapper installed (real binary at /usr/sbin/grub-mkconfig.distrib)"

# Ensure the post-install fixup script (shipped via includes.chroot) is runnable.
chmod +x /usr/local/bin/vitos-postinstall 2>/dev/null || true

# Make Debian's own grub postinst install a correct removable copy too
# (shim + grub + stub cfg, Secure-Boot-safe). Belt-and-suspenders alongside
# the wrapper; survives any later grub reconfiguration in the target.
echo 'grub-efi-amd64 grub2/force_efi_extra_removable boolean true' \
    | debconf-set-selections 2>/dev/null || true

# Remove old wrapper that relied on grubInstall config key (didn't work)
rm -f /usr/local/bin/grub-install-efi

cat > "$MODULES/bootloader.conf" << 'EOF'
---
efiBootLoader: "grub"
kernel: "/vmlinuz"
img: "/initrd.img"
timeout: 10
grubInstall: "grub-install"
grubMkconfig: "grub-mkconfig"
grubCfg: "/boot/grub/grub.cfg"
grubProbe: "grub-probe"
efiBootloaderId: "VITOS"
installEFIFallback: true
EOF

# ── grubcfg.conf — VITOS-branded GRUB defaults ─────────────
cat > "$MODULES/grubcfg.conf" << 'EOF'
---
distributor: "VITOS"
keepDistributor: true
cmdlineLinuxDefault: "quiet splash"
timeout: 10
EOF

# ── shellprocess@postinstall — EFI fixup & cleanup ─────────
cat > "$MODULES/shellprocess-postinstall.conf" << 'EOF'
---
dontChroot: false
timeout: 120
script:
    - "/usr/local/bin/vitos-postinstall"
EOF

# (vitos-postinstall is shipped via includes.chroot/usr/local/bin/vitos-postinstall)

# Optional Secure-Boot packages enable the signed shim removable path
# (best-effort; grub-efi + modules were already ensured/verified above).
for pkg in shim-signed grub-efi-amd64-signed; do
    if ! dpkg -s "$pkg" >/dev/null 2>&1; then
        echo "Installing optional Secure-Boot package: $pkg"
        apt-get install -y "$pkg" || true
    fi
done

cat > "$MODULES/users.conf" << 'EOF'
---
defaultGroups:
    - sudo
    - cdrom
    - floppy
    - audio
    - dip
    - video
    - plugdev
    - netdev
    - bluetooth
    - lpadmin
    - scanner
autologinGroup: autologin
doAutologin: false
setRootPassword: true
doReusePassword: true
passwordRequirements:
    minLength: 8
EOF

cat > "$MODULES/welcome.conf" << 'EOF'
---
showSupportUrl: true
showKnownIssuesUrl: true
showReleaseNotesUrl: false
requirements:
    requiredStorage: 20
    requiredRam: 2.0
    check:
        - storage
        - ram
    required:
        - storage
EOF

cat > "$MODULES/partition.conf" << 'EOF'
---
efiSystemPartition: "/boot/efi"
efiSystemPartitionSize: 512M
userSwapChoices:
    - none
    - small
    - file
drawNestedPartitions: false
alwaysShowPartitionLabels: true
defaultPartitionTableType: gpt
defaultFileSystemType: "ext4"
EOF

cat > "$MODULES/finished.conf" << 'EOF'
---
restartNowEnabled: true
restartNowChecked: true
restartNowCommand: "systemctl -i reboot"
EOF

cat > "$MODULES/locale.conf" << 'EOF'
---
region: "Asia"
zone: "Kolkata"
EOF

# ── Desktop entry ────────────────────────────────────────────
DESKTOP="/usr/share/applications/install-vitos.desktop"
if [ ! -f "$DESKTOP" ]; then
    cat > "$DESKTOP" << 'EOF'
[Desktop Entry]
Type=Application
Name=Install VITOS
GenericName=System Installer
Comment=Install VITOS to your hard drive
Exec=pkexec calamares
Icon=calamares
Terminal=false
Categories=System;
Keywords=installer;calamares;system;
EOF
fi

echo "=== VITOS Calamares dark theme configured ==="
