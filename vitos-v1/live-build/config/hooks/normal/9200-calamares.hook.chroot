#!/bin/sh
set -e

echo "=== Configuring VITOS Calamares dark theme ==="

if ! dpkg -s calamares >/dev/null 2>&1; then
    echo "Calamares not found — skipping theme setup"
    exit 0
fi

BRAND="/etc/calamares/branding/vitos"
MODULES="/etc/calamares/modules"

mkdir -p "$BRAND" "$MODULES"

# ── settings.conf ────────────────────────────────────────────
cat > /etc/calamares/settings.conf << 'SETTINGS'
---
modules-search: [ local, /usr/lib/calamares/modules ]
sequence:
  - show:
    - welcome
    - locale
    - keyboard
    - partition
    - users
    - summary
  - exec:
    - partition
    - mount
    - unpackfs
    - machineid
    - fstab
    - locale
    - keyboard
    - localecfg
    - networkcfg
    - hwclock
    - services-systemd
    - initramfscfg
    - initramfs
    - grubcfg
    - bootloader
    - shellprocess@postinstall
    - umount
  - show:
    - finished
branding: vitos
SETTINGS

# ── Resolve branding images ─────────────────────────────────
LOGO_REF="/usr/share/icons/hicolor/scalable/apps/calamares.svg"
ICON_REF="$LOGO_REF"

for candidate in \
    /usr/share/vitos/branding/calamares-logo.png \
    /usr/share/plymouth/themes/vitos/splash.png; do
    if [ -f "$candidate" ]; then
        LOGO_REF="$candidate"
        break
    fi
done

if [ -f /usr/share/vitos/branding/calamares-icon.png ]; then
    ICON_REF="/usr/share/vitos/branding/calamares-icon.png"
fi

# If convert is available, generate properly-sized branding images
if command -v convert >/dev/null 2>&1; then
    if [ -f /usr/share/plymouth/themes/vitos/splash.png ]; then
        convert /usr/share/plymouth/themes/vitos/splash.png \
            -gravity center -crop 600x400+0-100 +repage \
            -resize 320x "$BRAND/product-logo.png" 2>/dev/null && \
            LOGO_REF="product-logo.png" || true
    fi

    convert -size 64x64 xc:none \
        -fill '#4CB5F5' -draw 'roundrectangle 0,0 63,63 12,12' \
        -fill white -font DejaVu-Sans-Bold -pointsize 36 \
        -gravity center -annotate +0+0 'V' \
        "$BRAND/product-icon.png" 2>/dev/null && \
        ICON_REF="product-icon.png" || true
fi

# ── branding.desc ────────────────────────────────────────────
cat > "$BRAND/branding.desc" << BRAND
---
componentName: vitos
welcomeStyleCalamares: true
welcomeExpandingLogo: true

strings:
    productName:         "VITOS"
    shortProductName:    "VITOS"
    version:             "1.0.2"
    shortVersion:        "1.0"
    versionedName:       "VITOS 1.0.2"
    shortVersionedName:  "VITOS 1.0"
    bootloaderEntryName: "VITOS"
    productUrl:          "https://crypto0010.github.io/VITOS/"
    supportUrl:          "https://crypto0010.github.io/VITOS/"
    knownIssuesUrl:      "https://github.com/crypto0010/VITOS/issues"
    releaseNotesUrl:     "https://github.com/crypto0010/VITOS/releases"
    productDescription:  "Developed by Dr. Hemraj — VIT Bhopal University"

images:
    productLogo:         "${LOGO_REF}"
    productIcon:         "${ICON_REF}"

slideshow:               "show.qml"
slideshowAPI:            2

style:
    SidebarBackground:        "#080b20"
    SidebarText:              "#6b7394"
    SidebarTextSelect:        "#ffffff"
    SidebarTextHighlight:     "#4CB5F5"
    SidebarBackgroundCurrent: "#0d1117"

stylesheet: "stylesheet.qss"
BRAND

# ── stylesheet.qss ──────────────────────────────────────────
cat > "$BRAND/stylesheet.qss" << 'QSS'
/* VITOS Dark Theme for Calamares
   Palette: #0d1117 bg, #161b22 surface, #21262d elevated,
            #30363d border, #4CB5F5 accent, #e6edf3 text */

* {
    font-family: "Noto Sans", "DejaVu Sans", sans-serif;
}

#mainApp {
    background-color: #0d1117;
    color: #e6edf3;
}

#sidebarApp {
    background-color: #080b20;
}

#sidebarMenuApp {
    background-color: transparent;
    padding: 4px 0;
}

#logoApp {
    background-color: #080b20;
    padding: 12px;
}

QWidget {
    background-color: #0d1117;
    color: #e6edf3;
    font-size: 13px;
}

QLabel {
    color: #e6edf3;
    background-color: transparent;
}

QLabel#heading, QLabel[objectName="heading"] {
    font-size: 22px;
    font-weight: bold;
    color: #ffffff;
    padding-bottom: 4px;
}

QPushButton {
    background-color: #21262d;
    color: #e6edf3;
    border: 1px solid #30363d;
    border-radius: 6px;
    padding: 8px 20px;
    font-size: 13px;
    min-height: 32px;
    min-width: 80px;
}

QPushButton:hover {
    background-color: #30363d;
    border-color: #4CB5F5;
    color: #ffffff;
}

QPushButton:pressed {
    background-color: #0d1117;
}

QPushButton:disabled {
    background-color: #161b22;
    color: #484f58;
    border-color: #21262d;
}

#next, QPushButton[objectName="next"] {
    background-color: #4CB5F5;
    color: #0d1117;
    border: none;
    font-weight: bold;
    padding: 8px 28px;
}

#next:hover {
    background-color: #6dc8ff;
}

#next:pressed {
    background-color: #3a9fd8;
}

#cancel {
    background-color: transparent;
    border: 1px solid #30363d;
    color: #8b949e;
}

#cancel:hover {
    border-color: #f87171;
    color: #f87171;
}

#back {
    background-color: transparent;
    border: 1px solid #30363d;
    color: #8b949e;
}

#back:hover {
    border-color: #4CB5F5;
    color: #4CB5F5;
}

QLineEdit, QSpinBox, QDoubleSpinBox {
    background-color: #161b22;
    color: #e6edf3;
    border: 1px solid #30363d;
    border-radius: 6px;
    padding: 8px 12px;
    selection-background-color: #4CB5F5;
    selection-color: #0d1117;
}

QLineEdit:focus, QSpinBox:focus {
    border-color: #4CB5F5;
    background-color: #1c2128;
}

QComboBox {
    background-color: #161b22;
    color: #e6edf3;
    border: 1px solid #30363d;
    border-radius: 6px;
    padding: 6px 12px;
    min-height: 32px;
}

QComboBox:hover, QComboBox:focus {
    border-color: #4CB5F5;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
    background-color: transparent;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #8b949e;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #161b22;
    color: #e6edf3;
    border: 1px solid #30363d;
