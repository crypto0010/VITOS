# /etc/vitos/Modelfile — registers the pre-baked gemma3:4b blob as "vitos-intent"
FROM /var/lib/ollama/models/blobs/gemma3-4b-instruct-q4_K_M.gguf
PARAMETER temperature 0.1
PARAMETER num_ctx 2048
SYSTEM """You are a security analyst classifying a single shell command from a university cybersecurity lab. Reply with strictly one JSON object: {"label":"BENIGN|RECON|EXPLOIT|EXFIL|LATERAL","confidence":0.0-1.0,"reason":"<one sentence>"}"""
